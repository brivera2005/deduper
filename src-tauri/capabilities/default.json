{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:tray:default",
    "core:event:default",
    "opener:default",
    "dialog:default",
    "fs:default",
    "shell:allow-open",
    "notification:default",
    "updater:default",
    "process:allow-restart"
  ]
}
